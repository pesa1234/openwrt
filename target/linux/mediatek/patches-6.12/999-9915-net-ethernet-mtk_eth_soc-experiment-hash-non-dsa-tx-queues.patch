+static u16 mtk_tx_hash(struct net_device *dev, struct sk_buff *skb,
+		       struct net_device *sb_dev)
+{
+	u32 hash;
+	u16 qoffset = 0;
+	u16 qcount = dev->real_num_tx_queues;
+
+	sb_dev = sb_dev ? : dev;
+
+	if (dev->num_tc) {
+		u8 tc = netdev_get_prio_tc_map(dev, skb->priority);
+
+		qoffset = sb_dev->tc_to_txq[tc].offset;
+		qcount = sb_dev->tc_to_txq[tc].count;
+		if (unlikely(!qcount)) {
+			qoffset = 0;
+			qcount = dev->real_num_tx_queues;
+		}
+	}
+
+	if (skb_rx_queue_recorded(skb)) {
+		hash = skb_get_rx_queue(skb);
+		if (hash >= qoffset)
+			hash -= qoffset;
+		while (unlikely(hash >= qcount))
+			hash -= qcount;
+		return hash + qoffset;
+	}
+
+	return reciprocal_scale(skb_get_hash(skb), qcount) + qoffset;
+}
+
+static bool mtk_is_cake_txq(struct net_device *dev, unsigned int queue)
+{
+	struct netdev_queue *txq = netdev_get_tx_queue(dev, queue);
+	struct Qdisc *qdisc;
+	bool is_cake = false;
+
+	rcu_read_lock();
+	qdisc = rcu_dereference(txq->qdisc_sleeping);
+	if (qdisc && qdisc->ops && qdisc->ops->id &&
+	    !strcmp(qdisc->ops->id, "cake"))
+		is_cake = true;
+	rcu_read_unlock();
+
+	return is_cake;
 }
 
